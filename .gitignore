# Local environment backups
backups/*.json
backups/*.reg
backups/*.bak
backups/*.log

# Temporary or machine-specific artifacts
*.tmp
*.temp
*.log

# PowerShell local transient files
*.ps1~

# Optional local secrets or user-specific state
secrets/
*.pem
*.key
*.pfx

# PowerToys telemetry and runtime state files
configs/powertoys/**/settings-telemetry.json
configs/powertoys/**/log_settings.json
configs/powertoys/**/last_version_run.json
configs/powertoys/**/UpdateState.json
configs/powertoys/**/oobe_settings.json
